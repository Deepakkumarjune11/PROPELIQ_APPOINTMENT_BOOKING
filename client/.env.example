# PropelIQ Frontend — Environment Variables
# Copy this file to .env.local and fill in values for local development.
# NEVER commit .env.local or any file containing real credentials to source control.

# Base URL used by Axios in the browser (leave empty to use the Vite proxy in dev).
# Set to the deployed API origin for production builds, e.g. https://api.propeliq.io
VITE_API_URL=

# Backend origin that the Vite dev-server proxy forwards /api and /hubs to.
# Docker (default): http://localhost:8080  ← matches Dockerfile ASPNETCORE_URLS + compose port
# dotnet run (http profile): http://localhost:8080  ← set ASPNETCORE_URLS=http://localhost:8080
# Leave unset to use the built-in default (http://127.0.0.1:8080).
VITE_BACKEND_URL=http://localhost:8080
