# PropelIQ Frontend — Environment Variables
# Copy this file to .env.local and fill in values for local development.
# NEVER commit .env.local or any file containing real credentials to source control.

# Base URL for the PropelIQ .NET 8 backend API.
# Vite dev server proxies /api requests to this target (see vite.config.ts proxy).
# Set to the deployed API URL for production builds.
VITE_API_BASE_URL=http://localhost:5000
