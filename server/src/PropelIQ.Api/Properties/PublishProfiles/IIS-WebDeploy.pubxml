<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS Web Deploy publish profile — generates a local MSDeploy package (zip).
  Usage: dotnet publish src/PropelIQ.Api -p:PublishProfile=IIS-WebDeploy
  Output: src/PropelIQ.Api/publish/PropelIQ.zip
  The package can be deployed to IIS via Web Deploy or IIS Manager import.
  MSDeployPublishMethod=Package creates the zip locally without requiring a live server.
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>Package</WebPublishMethod>
    <PackageAsMSDeployment>true</PackageAsMSDeployment>
    <DeployIisAppPath>PropelIQ</DeployIisAppPath>
    <PackageLocation>publish\PropelIQ.zip</PackageLocation>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0</TargetFramework>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <!-- Ensure web.config is included in the deploy package -->
    <IncludeIISExpressConfig>false</IncludeIISExpressConfig>
  </PropertyGroup>
</Project>
