<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config for IIS hosting via AspNetCoreModuleV2 (InProcess).
  Required on Windows Server IIS for ASP.NET Core 8 forward-proxied through IIS.
  hostingModel="inprocess" — the app runs inside the IIS worker process (w3wp.exe)
  for better throughput and lower latency than out-of-process.
  stdoutLogEnabled should remain false in production; enable temporarily for diagnostics only.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\PropelIQ.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <!-- Override ASPNETCORE_ENVIRONMENT per IIS site configuration as needed -->
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
