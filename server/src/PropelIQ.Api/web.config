<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config for IIS hosting via AspNetCoreModuleV2 (InProcess).
  Required on Windows Server IIS for ASP.NET Core 8 forward-proxied through IIS.
  hostingModel="inprocess" — the app runs inside the IIS worker process (w3wp.exe)
  for better throughput and lower latency than out-of-process.
  stdoutLogEnabled should remain false in production; enable temporarily for diagnostics only.

  ─── TLS 1.3 Enforcement (IIS / Windows Schannel) ───────────────────────────────────────────────
  Kestrel enforces TLS 1.3 via ConfigureHttpsDefaults (see Program.cs).
  For IIS/Schannel (production), enforce TLS 1.3 and disable TLS 1.0/1.1/1.2 using:
    Tool:     IIS Crypto (Nartac) — https://www.nartac.com/Products/IISCrypto
    Registry: HKLM\SYSTEM\CurrentControlSet\Control\SecurityProviders\SCHANNEL\Protocols\
      TLS 1.3\Server\Enabled  = DWORD 1
      TLS 1.2\Server\Enabled  = DWORD 0 (or remove)
      TLS 1.1\Server\Enabled  = DWORD 0
      TLS 1.0\Server\Enabled  = DWORD 0
  Restart the W3SVC service after registry changes.
  DR-015 / AC-2 — production enforcement deferred to Windows Schannel per IIS hosting model.
  ────────────────────────────────────────────────────────────────────────────────────────────────
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\PropelIQ.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <!-- Override ASPNETCORE_ENVIRONMENT per IIS site configuration as needed -->
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
