# server/.env.example
# Copy this file to .env and fill in real values for local development.
# Never commit .env — it is in .gitignore.

# PostgreSQL
POSTGRES_DB=propeliq_dev
POSTGRES_USER=propeliq
POSTGRES_PASSWORD=CHANGE_ME

# Redis (leave empty for local dev — no auth required with redis:7-alpine defaults)
REDIS_PASSWORD=

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
