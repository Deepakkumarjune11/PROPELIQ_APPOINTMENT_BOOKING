# PropelIQ Backup Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# NEVER commit actual values. Copy this file to .env and fill in real values.
# Store secrets in Azure Key Vault (production) or Windows Credential Store.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection (use a dedicated backup-only user with REPLICATION privilege)
PGHOST=localhost
PGPORT=5432
PGUSER=propeliq_backup
PGPASSWORD=CHANGE_ME
PGDATABASE=postgres

# AES-256 file-level backup encryption passphrase (min 32 characters).
# This is SEPARATE from the column-level EF Data Protection key (US_027/task_001).
# Store in Azure Key Vault secret named "propeliq-backup-enc-passphrase".
BACKUP_ENCRYPTION_PASSPHRASE=CHANGE_ME_32_CHARS_MINIMUM

# Azure Blob Storage — use GRS (Geo-Redundant Storage) tier per DR-013.
# The migration-only DB user must NOT have access to AZURE_STORAGE_KEY.
AZURE_STORAGE_ACCOUNT=propeliqbackups
AZURE_STORAGE_KEY=CHANGE_ME
AZURE_CONTAINER=db-backups

# Local fallback directory — used ONLY when Azure is unavailable (48-hour retention).
# Must have sufficient disk space for at least one full backup.
LOCAL_FALLBACK_DIR=/var/backups/propeliq

# Optional: Slack webhook for failure alerts (non-blocking — leave empty to disable)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# Restore configuration (restore-validate.sh only)
RESTORE_PG_PORT=5433
