# ============================================================
# ROOT
# ============================================================
.env
.env.*
!.env.example
*.log

# ============================================================
# CLIENT — React / Vite / TypeScript
# ============================================================
client/node_modules/
client/dist/
client/.vite/
client/coverage/
client/*.local
client/.DS_Store

# TypeScript build info
client/tsconfig.tsbuildinfo
client/*.tsbuildinfo

# tsc compiled vite config output — Vite resolves .js before .ts, so these
# must never land next to vite.config.ts (outDir redirects them here instead)
client/vite.config.js
client/vite.config.d.ts
client/.tsc-node-out/

# ============================================================
# SERVER — .NET / C#
# ============================================================

# Build output
server/**/bin/
server/**/obj/
server/**/publish/
server/**/.vs/

# User-specific / IDE files
*.user
*.suo
*.userosscache
*.sln.docstates
.vscode/
.idea/

# NuGet
*.nupkg
*.snupkg
server/**/*.nuget.props
server/**/*.nuget.g.props
server/**/*.nuget.g.targets
server/**/project.assets.json
server/**/nuget.dgspec.json

# Entity Framework migrations (keep if you commit migrations)
# server/**/Migrations/

# ASP.NET Core — ignore all environment-specific overrides; keep only the base config
server/**/appsettings.*.json
!server/**/appsettings.json
!server/**/appsettings.*.json.example

# Secrets
server/**/*secrets*.json
server/**/*.pfx
server/**/*.p12

# ============================================================
# DOCKER
# ============================================================
.dockerignore

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# MISC
# ============================================================
*.tmp
*.swp
*.bak

# ============================================================
# BACKUP SCRIPTS — secrets
# ============================================================
# Never commit actual backup credentials — use .env.example as template
scripts/backup/.env
